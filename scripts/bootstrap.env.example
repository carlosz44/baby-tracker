# Baby Tracker — VPS bootstrap config
#
# Copy to `scripts/bootstrap.env` and fill in values, or export as env vars
# before running `scripts/bootstrap-vps.sh`. Empty required values will be
# prompted for interactively.
#
# Precedence: shell env vars > scripts/bootstrap.env > this file.

# ─── Required (prompted if empty) ─────────────────────────────────────────────
DOMAIN=
EMAIL=
ALLOWED_EMAILS=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_ENDPOINT=

# ─── Optional overrides ───────────────────────────────────────────────────────
DEPLOY_USER=deploy
# REPO_URL is auto-detected from `git remote get-url origin` when the script
# runs from inside a checked-out repo. Set explicitly to override.
REPO_URL=
APP_DIR=/var/www/baby-tracker
PYTHON_BIN=python3
DB_NAME=babytracker
DB_USER=baby
# DB_PASSWORD is auto-generated if left empty
DB_PASSWORD=
R2_BUCKET=baby-tracker
